<Window x:Class="TaskFlow.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:TaskFlow.Models"
        xmlns:helpers="clr-namespace:TaskFlow.Helpers"
        Title="TaskFlow - MVVM ToDo App" Height="700" Width="1300"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Enumeration values for ComboBoxes -->
        <ObjectDataProvider x:Key="PriorityEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:PriorityLevel"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="StatusEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:TaskStatus"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <helpers:DateToColorConverter x:Key="DateColorConverter" />

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="{Binding DueDate, Converter={StaticResource DateColorConverter}}"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <!-- Drag Drop handlers -->
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ListViewItem_PreviewMouseLeftButtonDown"/>
            <EventSetter Event="Drop" Handler="ListViewItem_Drop"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="ToolTip">
                <Setter.Value>
                    <TextBlock>
                        <Run Text="{Binding Title}" FontWeight="Bold"/>
                        <LineBreak/>
                        <Run Text="{Binding Description}"/>
                        <LineBreak/>
                        <Run Text="Due: "/><Run Text="{Binding DueDate, StringFormat=d}"/>
                    </TextBlock>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="AllowDrop" Value="True"/>
            <EventSetter Event="Drop" Handler="ListView_Drop"/>
            <EventSetter Event="DragOver" Handler="ListView_DragOver"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Top Panel: User Selection -->
        <DockPanel Grid.Row="0" Background="#2C3E50">
            <TextBlock Text="TaskFlow" Foreground="White" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                <TextBlock Text="User: " Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                <ComboBox Width="150" DisplayMemberPath="Name" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" Margin="0,15" Background="White"/>
                <TextBlock Text="Add User: " Foreground="White" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <TextBox Width="120" Text="{Binding NewUserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,15,5,15" Padding="5,2" VerticalContentAlignment="Center"/>
                <Button Content="Add User" Command="{Binding AddUserCommand}" Margin="0,15,5,15" Padding="12,0" Background="#27AE60" Foreground="White"/>
                <Button Content="Sort Priority" Command="{Binding SortPriorityCommand}" Margin="15,15,5,15" Padding="15,0" Background="#34495E" Foreground="White"/>
                <Button Content="Sort Due Date" Command="{Binding SortDueDateCommand}" Margin="5,15,5,15" Padding="15,0" Background="#34495E" Foreground="White"/>
                <Button Content="Export CSV" Command="{Binding ExportCommand}" Margin="5,15,0,15" Padding="15,0" Background="#34495E" Foreground="White"/>
            </StackPanel>
        </DockPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <Border Grid.Column="0" Background="#F4F6F7" BorderBrush="#DFE6E9" BorderThickness="0,0,1,0">
                <StackPanel Margin="15">
                    <TextBlock Text="Filters" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    <TextBlock Text="Category" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Margin="0,5,0,20"/>
                    <TextBlock Text="Instructions:" FontWeight="Bold" Margin="0,20,0,5"/>
                    <TextBlock Text="Drag and drop tasks between columns to change status. Overdue tasks are highlighted." TextWrapping="Wrap" Foreground="#7F8C8D"/>
                </StackPanel>
            </Border>

            <!-- Center Panel: 3 Columns -->
            <Grid Grid.Column="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Todo -->
                <DockPanel Grid.Column="0" Margin="5">
                    <Border DockPanel.Dock="Top" Background="#ECF0F1" Padding="10">
                        <TextBlock Text="To Do" FontSize="16" FontWeight="Bold" Foreground="#34495E" />
                    </Border>
                    <ListView x:Name="LvTodo" ItemsSource="{Binding TodoTasks}" SelectedItem="{Binding SelectedTask}" Tag="Todo">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="150"/>
                                <GridViewColumn Header="Priority" DisplayMemberBinding="{Binding Priority}" Width="70"/>
                                <GridViewColumn Header="Due" DisplayMemberBinding="{Binding DueDate, StringFormat=MMM dd}" Width="60"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>

                <!-- InProgress -->
                <DockPanel Grid.Column="1" Margin="5">
                    <Border DockPanel.Dock="Top" Background="#EBF5FB" Padding="10">
                        <TextBlock Text="In Progress" FontSize="16" FontWeight="Bold" Foreground="#2980B9" />
                    </Border>
                    <ListView x:Name="LvInProgress" ItemsSource="{Binding InProgressTasks}" SelectedItem="{Binding SelectedTask}" Tag="InProgress">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="150"/>
                                <GridViewColumn Header="Priority" DisplayMemberBinding="{Binding Priority}" Width="70"/>
                                <GridViewColumn Header="Due" DisplayMemberBinding="{Binding DueDate, StringFormat=MMM dd}" Width="60"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>

                <!-- Done -->
                <DockPanel Grid.Column="2" Margin="5">
                    <Border DockPanel.Dock="Top" Background="#EAFAF1" Padding="10">
                        <TextBlock Text="Done" FontSize="16" FontWeight="Bold" Foreground="#27AE60" />
                    </Border>
                    <ListView x:Name="LvDone" ItemsSource="{Binding DoneTasks}" SelectedItem="{Binding SelectedTask}" Tag="Done">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="150"/>
                                <GridViewColumn Header="Priority" DisplayMemberBinding="{Binding Priority}" Width="70"/>
                                <GridViewColumn Header="Due" DisplayMemberBinding="{Binding DueDate, StringFormat=MMM dd}" Width="60"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Grid>

            <!-- Right Panel: Editor -->
            <Border Grid.Column="2" Background="#FAFAFA" BorderBrush="#DFE6E9" BorderThickness="1,0,0,0">
                <StackPanel Margin="20">
                    <TextBlock Text="Task Editor" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Title" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding TaskToEdit.Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Padding="5"/>
                    
                    <TextBlock Text="Description" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding TaskToEdit.Description, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,5,0,15" Padding="5"/>
                    
                    <Grid Margin="0,5,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Due Date" FontWeight="SemiBold"/>
                            <DatePicker SelectedDate="{Binding TaskToEdit.DueDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Priority" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource PriorityEnum}}" SelectedItem="{Binding TaskToEdit.Priority, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,5,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Status" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource StatusEnum}}" SelectedItem="{Binding TaskToEdit.Status, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Category" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding TaskToEdit.Category, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="New" Click="BtnNew_Click" Margin="0,0,10,0" Padding="15,5" Background="#BDC3C7"/>
                        <Button Content="Add Task" Command="{Binding AddCommand}" Background="#2ECC71" Foreground="White" Margin="0,0,10,0" Padding="15,5"/>
                        <Button Content="Update" Command="{Binding EditCommand}" Background="#3498DB" Foreground="White" Margin="0,0,10,0" Padding="15,5"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}" Background="#E74C3C" Foreground="White" Padding="15,5"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Stat Bar -->
        <StatusBar Grid.Row="2" Background="#ECF0F1">
            <StatusBarItem Margin="10,0">
                <TextBlock Foreground="#2C3E50" FontWeight="Bold">
                    <Run Text="Total Tasks Context: "/>
                    <Run Text="{Binding TotalTasks}"/>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right" Margin="0,0,10,0">
                <TextBlock x:Name="TxtTimerAlert" Foreground="#C0392B" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
